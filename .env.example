# Copy this file to .env and fill in real values. .env is gitignored - never
# commit real credentials.
#
# Used two ways:
#
# 1. By tests/integration/*.php directly, to build a real settings row for
#    a one-off real-network smoke test against the Amazon PA-API.
# 2. As a fallback inside Product_Service::get_user_settings() - when a user
#    has no settings row in the database, Amazon-touching operations
#    (create, reactivate, refresh, connectivity checks) fall back to these
#    credentials instead of returning "not configured". This lets that
#    functionality be exercised locally (manually via wp-admin, or via
#    component/integration tests) without first going through the Settings
#    API - while the Settings API's own add/remove/retrieve behavior is
#    untouched, since it always reads the real database.
#
# A deployed install never has a .env file, so this fallback is always
# inert there - see includes/Helpers/Env_File.php.

APT_TEST_PA_API_ACCESS_KEY=
APT_TEST_PA_API_SECRET_KEY=
APT_TEST_PA_API_PARTNER_TAG=

# Optional - default UK.
APT_TEST_PA_API_REGION=UK

# Optional - only used by tests/integration/*.php, a known-good ASIN to
# fetch. Defaults to a known-good UK ASIN if unset.
APT_TEST_PA_API_ASIN=

# Amazon Creators API (PA-API's OAuth2-based replacement - see
# Amazon_Creators_API.php). A separate credential set from the PA-API keys
# above, by design: both can be set at once, letting Product_Service pick
# which implementation to build via Amazon_API::from_settings() vs.
# Amazon_Creators_API::from_settings() against the same settings row.
#
# Amazon's own documentation names 5 fields per credential: Credential ID,
# Credential Secret, Version, Marketplace, and Partner Tag. Marketplace
# isn't one of the env vars below, though - Amazon's own SDK treats it as a
# per-call parameter, not part of the stored credential (its Configuration
# class only holds credentialId/credentialSecret/version), so
# Amazon_Creators_API derives it per request from the region code via
# Regions::get_marketplace_domain(), same as the legacy PA-API client -
# necessary for one credential to correctly serve every region this user
# has a partner tag for, rather than being pinned to a single marketplace.

APT_TEST_CREATORS_API_CREDENTIAL_ID=
APT_TEST_CREATORS_API_CREDENTIAL_SECRET=

# Identifies which auth flavor/regional cluster your credential was issued
# for. Cognito (v2.x): "2.1" NA, "2.2" EU, "2.3" FE.
# Login-with-Amazon (v3.x): "3.1" NA, "3.2" EU, "3.3" FE.
# Either "3.2" or "v3.2" is accepted - Amazon_Creators_API strips a leading
# "v"/"V" before matching, since Associates Central displays it with one.
APT_TEST_CREATORS_API_VERSION=

APT_TEST_CREATORS_API_PARTNER_TAG=

# Optional - default UK.
APT_TEST_CREATORS_API_REGION=UK
