{
    "name": "infection/abstract-testframework-adapter",
    "description": "Abstract Test Framework Adapter for Infection",
    "license": "BSD-3-Clause",
    "type": "library",
    "authors": [
        {
            "name": "Maks Rafalko",
            "email": "maks.rafalko@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "ergebnis/composer-normalize": "^2.18",
        "fidry/makefile": "^1.0",
        "friendsofphp/php-cs-fixer": "^3.95.2",
        "phpunit/phpunit": "^12.0 || ^13.0",
        "rector/rector": "^2.4.5"
    },
    "autoload": {
        "psr-4": {
            "Infection\\AbstractTestFramework\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Infection\\AbstractTestFramework\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true
        },
        "sort-packages": true
    }
}
