    {
      "name": "Settings",
      "description": "User Amazon PA-API settings management",
      "item": [
        {
          "name": "GET /settings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{api_base}}/settings",
              "host": ["{{api_base}}"],
              "path": ["settings"]
            },
            "description": "Get current user's Amazon PA-API settings.\n\nNote: secret_key is NEVER returned in responses."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"id\": 1,\n  \"user_id\": 42,\n  \"access_key\": \"AKIA****EXAMPLE\",\n  \"partner_tags\": {\n    \"US\": \"mysite-20\",\n    \"UK\": \"mysite-21\"\n  },\n  \"created_at\": \"2024-01-10T08:00:00+00:00\",\n  \"updated_at\": \"2024-01-15T12:30:00+00:00\"\n}"
            },
            {
              "name": "Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"code\": \"NOT_FOUND\",\n  \"message\": \"User settings not configured\"\n}"
            }
          ]
        },
        {
          "name": "PUT /settings",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
