    {
      "name": "Products",
      "description": "Product tracking and management",
      "item": [
        {
          "name": "GET /products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{api_base}}/products?page=1&per_page=20&is_active=true&sort_by=created_at&sort_order=desc",
              "host": ["{{api_base}}"],
              "path": ["products"],
              "query": [
                {"key": "page", "value": "1"},
                {"key": "per_page", "value": "20"},
                {"key": "region", "value": "US", "disabled": true},
                {"key": "regions", "value": "US,UK,DE", "disabled": true},
                {"key": "custom_category", "value": "Electronics", "disabled": true},
                {"key": "search", "value": "wireless", "disabled": true},
                {"key": "min_price", "value": "10.00", "disabled": true},
                {"key": "max_price", "value": "100.00", "disabled": true},
                {"key": "availability", "value": "in_stock", "disabled": true},
                {"key": "is_active", "value": "true"},
                {"key": "sort_by", "value": "created_at"},
                {"key": "sort_order", "value": "desc"}
              ]
            },
            "description": "Get paginated list of tracked products.\n\nSupports filtering by region, category, price range, availability, and search.\n\nSort by: created_at, updated_at, current_price, title, asin"
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"data\": [\n    {\n      \"id\": 123,\n      \"asin\": \"B08N5WRWNW\",\n      \"region\": \"US\",\n      \"title\": \"Product Name\",\n      \"custom_category\": \"Electronics\",\n      \"is_active\": true,\n      \"current_price\": 29.99,\n      \"currency\": \"USD\",\n      \"availability\": \"in_stock\",\n      \"created_at\": \"2024-01-15T10:30:00+00:00\",\n      \"updated_at\": \"2024-01-15T14:45:00+00:00\"\n    }\n  ],\n  \"meta\": {\n    \"pagination\": {\n      \"current_page\": 1,\n      \"per_page\": 20,\n      \"total_items\": 150,\n      \"total_pages\": 8,\n      \"has_next\": true,\n      \"has_previous\": false\n    }\n  }\n}"
            }
          ]
        },
        {
          "name": "POST /products",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"asin\": \"B08N5WRWNW\",\n  \"region\": \"US\"\n}"
            },
            "url": {
              "raw": "{{api_base}}/products",
              "host": ["{{api_base}}"],
              "path": ["products"]
            },
            "description": "Create a new tracked product.\n\nProcess:\n1. Validate ASIN format (10 alphanumeric)\n2. Check blacklist\n3. Check if already exists\n4. Validate user has partner tag for region\n5. Fetch from Amazon PA-API\n6. Create product with images, facts, initial price\n\nRate limit: 50/day for non-admin users"
          },
          "response": [
            {
              "name": "Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"id\": 123,\n  \"asin\": \"B08N5WRWNW\",\n  \"region\": \"US\",\n  \"custom_category\": null,\n  \"images\": [\n    {\n      \"url\": \"https://m.media-amazon.com/images/I/xxxxx.jpg\",\n      \"height\": 500,\n      \"width\": 500,\n      \"type\": \"main\"\n    }\n  ],\n  \"facts\": {\n    \"title\": \"Product Name\",\n    \"brand\": \"Brand Name\",\n    \"rating\": 4.5,\n    \"review_count\": 1250\n  },\n  \"is_active\": true,\n  \"created_at\": \"2024-01-15T10:30:00+00:00\",\n  \"updated_at\": \"2024-01-15T10:30:00+00:00\",\n  \"created_by\": 42\n}"
            },
            {
              "name": "Blacklisted",
              "status": "Forbidden",
              "code": 403,
              "body": "{\n  \"code\": \"BLACKLISTED\",\n  \"message\": \"This ASIN/Region combination is blacklisted\",\n  \"details\": {\n    \"reason\": \"Prohibited product category\"\n  }\n}"
            },
            {
              "name": "Already Exists",
              "status": "Conflict",
              "code": 409,
              "body": "{\n  \"code\": \"ALREADY_EXISTS\",\n  \"message\": \"Product with this ASIN/Region already exists\",\n  \"details\": {\n    \"id\": 123\n  }\n}"
            },
            {
              "name": "Rate Limited",
              "status": "Too Many Requests",
              "code": 429,
              "body": "{\n  \"code\": \"RATE_LIMIT_EXCEEDED\",\n  \"message\": \"Daily creation limit exceeded\",\n  \"details\": {\n    \"limit\": 50,\n    \"used\": 50,\n    \"resets_at\": \"2024-01-16T00:00:00+00:00\"\n  }\n}"
            }
          ]
        },
        {
          "name": "POST /products/bulk",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"products\": [\n    {\"asin\": \"B08N5WRWNW\", \"region\": \"US\"},\n    {\"asin\": \"B08N5WRWNW\", \"region\": \"UK\"},\n    {\"asin\": \"B09V3KXJPB\", \"region\": \"US\"}\n  ]\n}"
            },
            "url": {
              "raw": "{{api_base}}/products/bulk",
              "host": ["{{api_base}}"],
              "path": ["products", "bulk"]
            },
            "description": "Create multiple products in a single request.\n\nMaximum 100 products per request.\nCounts against daily rate limit for non-admin users.\n\nReturns success/failure count with individual results."
          },
          "response": [
            {
              "name": "Partial Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success_count\": 2,\n  \"failure_count\": 1,\n  \"results\": [\n    {\n      \"asin\": \"B08N5WRWNW\",\n      \"region\": \"US\",\n      \"success\": true,\n      \"product\": {\"id\": 123, \"...\"}\n    },\n    {\n      \"asin\": \"B08N5WRWNW\",\n      \"region\": \"UK\",\n      \"success\": true,\n      \"product\": {\"id\": 124, \"...\"}\n    },\n    {\n      \"asin\": \"B09V3KXJPB\",\n      \"region\": \"US\",\n      \"success\": false,\n      \"error\": {\n        \"code\": \"ASIN_NOT_FOUND\",\n        \"message\": \"Product not found on Amazon\"\n      }\n    }\n  ]\n}"
            }
          ]
        },
        {
          "name": "POST /products/refresh (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_ids\": [1, 2, 3],\n  \"regions\": [\"US\", \"UK\"],\n  \"limit\": 100\n}"
            },
            "url": {
              "raw": "{{api_base}}/products/refresh",
              "host": ["{{api_base}}"],
              "path": ["products", "refresh"]
            },
            "description": "Trigger price refresh for multiple products (Admin only).\n\nAll parameters are optional:\n- product_ids: Specific product IDs to refresh\n- regions: Filter by regions\n- limit: Max products to refresh (default 100, max 1000)\n\nIf Amazon PA-API fails, existing price remains unchanged."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success_count\": 95,\n  \"failure_count\": 5,\n  \"results\": []\n}"
            }
          ]
        },
        {
          "name": "GET /products/{id}",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{api_base}}/products/{{test_product_id}}",
              "host": ["{{api_base}}"],
              "path": ["products", "{{test_product_id}}"]
            },
            "description": "Get full product details by ID.\n\nReturns complete product object with images, facts, and metadata."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"id\": 123,\n  \"asin\": \"B08N5WRWNW\",\n  \"region\": \"US\",\n  \"custom_category\": \"Electronics\",\n  \"images\": [],\n  \"facts\": {},\n  \"is_active\": true,\n  \"created_at\": \"2024-01-15T10:30:00+00:00\",\n  \"updated_at\": \"2024-01-15T14:45:00+00:00\",\n  \"created_by\": 42\n}"
            },
            {
              "name": "Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"code\": \"NOT_FOUND\",\n  \"message\": \"Product not found\"\n}"
            }
          ]
        },
        {
          "name": "DELETE /products/{id} (Admin)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{api_base}}/products/{{test_product_id}}?force=false",
              "host": ["{{api_base}}"],
              "path": ["products", "{{test_product_id}}"],
              "query": [
                {"key": "force", "value": "false"}
              ]
            },
            "description": "Delete a product (Admin only).\n\n- force=false (default): Soft delete (is_active=false, history preserved)\n- force=true: Hard delete (permanently remove product AND all price history)"
          },
          "response": [
            {
              "name": "Success",
              "status": "No Content",
              "code": 204,
              "body": ""
            }
          ]
        },
        {
          "name": "PUT /products/{id}/category (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"custom_category\": \"Electronics\"\n}"
            },
            "url": {
              "raw": "{{api_base}}/products/{{test_product_id}}/category",
              "host": ["{{api_base}}"],
              "path": ["products", "{{test_product_id}}", "category"]
            },
            "description": "Update custom category for a product (Admin only).\n\nSet to null to remove category."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"id\": 123,\n  \"asin\": \"B08N5WRWNW\",\n  \"region\": \"US\",\n  \"custom_category\": \"Electronics\",\n  \"...\": \"...\"\n}"
            }
          ]
        },
        {
          "name": "GET /products/{id}/prices",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{api_base}}/products/{{test_product_id}}/prices?page=1&per_page=20&sort_order=desc",
              "host": ["{{api_base}}"],
              "path": ["products", "{{test_product_id}}", "prices"],
              "query": [
                {"key": "page", "value": "1"},
                {"key": "per_page", "value": "20"},
                {"key": "from", "value": "2024-01-01T00:00:00Z", "disabled": true},
                {"key": "to", "value": "2024-01-31T23:59:59Z", "disabled": true},
                {"key": "aggregate", "value": "daily", "disabled": true},
                {"key": "sort_order", "value": "desc"}
              ]
            },
            "description": "Get price history for a product.\n\nSupports date range filtering and aggregations (none, daily, weekly, monthly).\n\nAggregations return min/max/avg for price and RRP."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"product\": {\n    \"id\": 123,\n    \"asin\": \"B08N5WRWNW\",\n    \"region\": \"US\",\n    \"title\": \"Product Name\"\n  },\n  \"currency\": \"USD\",\n  \"data\": [\n    {\n      \"id\": 456,\n      \"product_id\": 123,\n      \"rrp\": 39.99,\n      \"current_price\": 29.99,\n      \"is_prime_price\": false,\n      \"availability\": \"in_stock\",\n      \"recorded_at\": \"2024-01-15T14:45:00+00:00\"\n    }\n  ],\n  \"meta\": {\n    \"pagination\": {\n      \"current_page\": 1,\n      \"per_page\": 20,\n      \"total_items\": 45,\n      \"total_pages\": 3,\n      \"has_next\": true,\n      \"has_previous\": false\n    }\n  }\n}"
            },
