{
  "info": {
    "_postman_id": "apt-api-collection-v1",
    "name": "Amazon Price Tracker API",
    "description": "Complete API collection for the Amazon Price Tracker WordPress plugin.\n\n## Authentication\nUses WordPress Application Passwords with HTTP Basic Auth.\n\n## Setup\n1. Set the `base_url` variable to your WordPress site\n2. Set `username` and `app_password` variables\n3. Run requests in order for initial setup\n\n## Base URI\n`{{base_url}}/wp-json/amazon-price-tracker/v1`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "basic",
    "basic": [
      {
        "key": "username",
        "value": "{{username}}",
        "type": "string"
      },
      {
        "key": "password",
        "value": "{{app_password}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://your-site.com",
      "type": "string"
    },
    {
      "key": "username",
      "value": "your-username",
      "type": "string"
    },
    {
      "key": "app_password",
      "value": "xxxx xxxx xxxx xxxx xxxx xxxx",
      "type": "string"
    },
    {
      "key": "api_base",
      "value": "{{base_url}}/wp-json/amazon-price-tracker/v1",
      "type": "string"
    },
    {
      "key": "test_product_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "test_asin",
      "value": "B08N5WRWNW",
      "type": "string"
    },
    {
      "key": "test_region",
      "value": "US",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "description": "API health check endpoints",
      "item": [
        {
          "name": "GET /health (Public)",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{api_base}}/health",
              "host": ["{{api_base}}"],
              "path": ["health"]
            },
            "description": "Public health check - no authentication required.\n\nReturns API status, version, WordPress version, PHP version, and timestamp."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"healthy\",\n  \"version\": \"1.0.0\",\n  \"wordpress_version\": \"6.4.2\",\n  \"php_version\": \"8.2.0\",\n  \"timestamp\": \"2024-01-15T14:45:00+00:00\"\n}"
            }
          ]
        },
        {
          "name": "GET /health/amazon",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{api_base}}/health/amazon",
              "host": ["{{api_base}}"],
              "path": ["health", "amazon"]
            },
            "description": "Test Amazon PA-API connectivity with user's configured credentials.\n\nReturns connection status, message, and response time."
          },
          "response": [
            {
              "name": "Connected",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"connected\",\n  \"message\": \"Successfully connected to Amazon PA-API\",\n  \"response_time_ms\": 245\n}"
            },
            {
              "name": "Not Configured",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"not_configured\",\n  \"message\": \"Amazon PA-API credentials not configured\"\n}"
            }
          ]
        }
      ]
    },
    {
