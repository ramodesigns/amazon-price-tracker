          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "[\n  {\n    \"id\": 123,\n    \"asin\": \"B08N5WRWNW\",\n    \"region\": \"US\",\n    \"...\": \"...\"\n  },\n  {\n    \"id\": 124,\n    \"asin\": \"B08N5WRWNW\",\n    \"region\": \"UK\",\n    \"...\": \"...\"\n  }\n]"
            }
          ]
        },
        {
          "name": "GET /products/by-asin/{asin}/{region}",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{api_base}}/products/by-asin/{{test_asin}}/{{test_region}}",
              "host": ["{{api_base}}"],
              "path": ["products", "by-asin", "{{test_asin}}", "{{test_region}}"]
            },
