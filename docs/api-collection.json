              "code": 200,
              "body": "{\n  \"product\": {\"...\"},\n  \"currency\": \"USD\",\n  \"data\": [],\n  \"aggregations\": [\n    {\n      \"period_start\": \"2024-01-01T00:00:00+00:00\",\n      \"period_end\": \"2024-01-31T23:59:59+00:00\",\n      \"min_price\": 24.99,\n      \"max_price\": 34.99,\n      \"avg_price\": 29.49,\n      \"min_rrp\": 39.99,\n      \"max_rrp\": 39.99,\n      \"avg_rrp\": 39.99,\n      \"record_count\": 31\n    }\n  ],\n  \"meta\": {\"...\"}\n}"
            }
          ]
        },
        {
          "name": "POST /products/{id}/refresh (Admin)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{api_base}}/products/{{test_product_id}}/refresh",
