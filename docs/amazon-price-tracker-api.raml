#%RAML 1.0
title: Amazon Price Tracker API
description: |
  A WordPress REST API plugin for tracking Amazon product prices across multiple 
  international marketplaces. Integrates with Amazon Product Advertising API 5.0 
  to fetch real-time pricing and product information, storing historical data 
  for price tracking over time.
version: v1
baseUri: https://{domain}/wp-json/amazon-price-tracker/v1
baseUriParameters:
  domain:
    description: The WordPress installation domain
    type: string
    example: example.com

mediaType: application/json

securitySchemes:
  basicAuth:
    description: |
      WordPress Application Passwords using HTTP Basic Authentication.
      All endpoints require authentication unless otherwise specified.
    type: Basic Authentication

securedBy: [basicAuth]

#===============================================================================
# TYPES
#===============================================================================

types:
  #-----------------------------------------------------------------------------
  # Enums
  #-----------------------------------------------------------------------------
  RegionCode:
    description: Supported Amazon marketplace region codes
    type: string
    enum: [US, CA, UK, DE, FR, ES, IT, AU, JP, IN, MX, BR]
  
  CurrencyCode:
    description: Currency codes for supported regions
    type: string
    enum: [USD, CAD, GBP, EUR, AUD, JPY, INR, MXN, BRL]
  
  AvailabilityStatus:
    description: Product availability status from Amazon
    type: string
    enum: [in_stock, out_of_stock, limited_stock, preorder, unknown]
  
  AggregationType:
    description: Aggregation period for price history
    type: string
    enum: [none, daily, weekly, monthly]
  
  SortOrder:
    description: Sort direction
    type: string
    enum: [asc, desc]
  
  ProductSortField:
    description: Fields available for sorting products
    type: string
    enum: [created_at, updated_at, current_price, title, asin]
  
  HealthStatus:
    description: Health check status values
    type: string
    enum: [connected, error, not_configured]

  #-----------------------------------------------------------------------------
  # Common Types
  #-----------------------------------------------------------------------------
  ASIN:
    description: Amazon Standard Identification Number (10 alphanumeric characters)
    type: string
    pattern: ^[A-Z0-9]{10}$
    example: B08N5WRWNW

  Pagination:
    description: Pagination metadata for list responses
    type: object
    properties:
      current_page:
        type: integer
        minimum: 1
        example: 1
      per_page:
        type: integer
        minimum: 1
        maximum: 100
        example: 20
      total_items:
        type: integer
        minimum: 0
        example: 150
      total_pages:
        type: integer
        minimum: 0
        example: 8
      has_next:
        type: boolean
        example: true
      has_previous:
        type: boolean
        example: false

  #-----------------------------------------------------------------------------
  # Error Types
  #-----------------------------------------------------------------------------
  Error:
    description: Standard error response
    type: object
    properties:
      code:
        type: string
        description: Machine-readable error code
        example: ERROR_CODE
      message:
        type: string
        description: Human-readable error message
        example: Human readable message
      details:
        type: object
        description: Additional error details
        required: false

  ValidationError:
    description: Validation error response with field-level details
    type: object
    properties:
      code:
        type: string
        enum: [VALIDATION_ERROR]
        example: VALIDATION_ERROR
      message:
        type: string
        example: Request validation failed
      errors:
        type: array
        items:
          type: object
          properties:
            field:
              type: string
              example: asin
            message:
              type: string
              example: ASIN must be 10 alphanumeric characters

  RateLimitError:
    description: Rate limit exceeded error
    type: object
    properties:
      code:
        type: string
        enum: [RATE_LIMIT_EXCEEDED]
      message:
        type: string
        example: Daily creation limit exceeded
      details:
        type: object
        properties:
          limit:
            type: integer
            example: 50
          used:
            type: integer
            example: 50
          resets_at:
            type: datetime
            example: 2024-01-16T00:00:00Z

  BlacklistedError:
    description: ASIN/Region is blacklisted error
    type: object
    properties:
      code:
        type: string
        enum: [BLACKLISTED]
      message:
        type: string
        example: This ASIN/Region combination is blacklisted
      details:
        type: object
        properties:
          reason:
            type: string
            required: false
            example: Prohibited product category

  #-----------------------------------------------------------------------------
  # Region Types
  #-----------------------------------------------------------------------------
  Region:
    description: Amazon marketplace region information
    type: object
    properties:
      code:
        type: RegionCode
        example: US
      name:
        type: string
        example: United States
      marketplace_domain:
        type: string
        example: amazon.com
      currency:
        type: CurrencyCode
        example: USD

  #-----------------------------------------------------------------------------
  # Product Types
  #-----------------------------------------------------------------------------
  ProductImage:
    description: Product image information
    type: object
    properties:
      url:
        type: string
        format: uri
        example: https://m.media-amazon.com/images/I/xxxxx.jpg
      height:
        type: integer
        example: 500
      width:
        type: integer
        example: 500
      type:
        type: string
        enum: [main, variant]
        example: main

  ProductFacts:
    description: |
      Flexible key-value pairs of product data from Amazon.
      Stores as much product information as Amazon PA-API returns.
    type: object
    properties:
      title:
        type: string
        required: false
        example: Product Name
      brand:
        type: string
        required: false
        example: Brand Name
      manufacturer:
        type: string
        required: false
        example: Manufacturer Name
      features:
        type: array
        items: string
        required: false
        example: ["Feature 1", "Feature 2", "Feature 3"]
      description:
        type: string
        required: false
        example: Product description
      amazon_category:
        type: string
        required: false
        example: Electronics > Computers > Accessories
      amazon_category_id:
        type: string
        required: false
        example: "123456"
      dimensions:
        type: string
        required: false
        example: 10 x 5 x 2 inches
      weight:
        type: string
        required: false
        example: 1.5 pounds
      rating:
        type: number
        required: false
        example: 4.5
      review_count:
        type: integer
        required: false
        example: 1250
      color:
        type: string
        required: false
        example: Black
      size:
        type: string
        required: false
        example: Large
      model_number:
        type: string
        required: false
        example: ABC123
      part_number:
        type: string
        required: false
        example: XYZ789
      release_date:
        type: date-only
        required: false
        example: 2024-01-15
      is_prime_eligible:
        type: boolean
        required: false
        example: true
      parent_asin:
        type: string
        required: false
        example: B000000000
      variation_attributes:
        type: array
        items: string
        required: false
        example: ["Color", "Size"]

  Product:
    description: Tracked product with metadata
    type: object
    properties:
      id:
        type: integer
        description: Unique product ID
        example: 123
      asin:
        type: ASIN
        example: B08N5WRWNW
      region:
        type: RegionCode
        example: US
      custom_category:
        type: string | nil
        description: Admin-assigned category (NOT Amazon's category)
        example: Electronics
      images:
        type: array
        items: ProductImage
      facts:
        type: ProductFacts
      is_active:
        type: boolean
        description: True = active, False = soft-deleted
        example: true
      created_at:
        type: datetime
        example: 2024-01-15T10:30:00Z
      updated_at:
        type: datetime
        example: 2024-01-15T14:45:00Z
      created_by:
        type: integer
        description: WordPress user ID who created entry
        example: 42

  ProductSummary:
    description: Summarized product information for list views
    type: object
    properties:
      id:
        type: integer
        example: 123
      asin:
        type: ASIN
        example: B08N5WRWNW
      region:
        type: RegionCode
        example: US
      title:
        type: string
        example: Product Name
      custom_category:
        type: string | nil
        example: Electronics
      is_active:
        type: boolean
        example: true
      current_price:
        type: number | nil
        description: Most recent price
        example: 29.99
      currency:
        type: CurrencyCode
        example: USD
      availability:
        type: AvailabilityStatus
        example: in_stock
      created_at:
        type: datetime
        example: 2024-01-15T10:30:00Z
      updated_at:
        type: datetime
        example: 2024-01-15T14:45:00Z

  ProductCreateRequest:
    description: Request to create a new tracked product
    type: object
    properties:
      asin:
        type: ASIN
        example: B08N5WRWNW
      region:
        type: RegionCode
        example: US

  ProductBulkCreateRequest:
    description: Request to create multiple tracked products
    type: object
    properties:
      products:
        type: array
        items: ProductCreateRequest
        minItems: 1
        maxItems: 100

  ProductBulkResult:
    description: Result of a bulk product operation
    type: object
    properties:
      success_count:
        type: integer
        example: 8
      failure_count:
        type: integer
        example: 2
      results:
        type: array
        items:
          type: object
          properties:
            asin:
              type: ASIN
            region:
              type: RegionCode
            success:
              type: boolean
            product:
              type: Product
              required: false
            error:
              type: Error
              required: false

  ProductRefreshRequest:
    description: Request to refresh prices for products
    type: object
    properties:
      product_ids:
        type: array
        items: integer
        required: false
        description: Optional array of specific product IDs to refresh
      regions:
        type: array
        items: RegionCode
        required: false
        description: Optional array of regions to filter by
      limit:
        type: integer
        default: 100
        maximum: 1000
        required: false
        description: Maximum number of products to refresh

  CategoryUpdateRequest:
    description: Request to update product custom category
    type: object
    properties:
      custom_category:
        type: string | nil
        description: New category name or null to remove
        example: Electronics

  #-----------------------------------------------------------------------------
  # Price Types
  #-----------------------------------------------------------------------------
  PriceRecord:
    description: Historical price record
    type: object
    properties:
      id:
        type: integer
        example: 456
      product_id:
        type: integer
        example: 123
      rrp:
        type: number | nil
        description: Recommended Retail Price (list price)
        example: 39.99
      current_price:
        type: number | nil
        description: Current selling price (NULL if unavailable)
        example: 29.99
      is_prime_price:
        type: boolean
        description: Whether this is a Prime-exclusive price
        example: false
      availability:
        type: AvailabilityStatus
        example: in_stock
      recorded_at:
        type: datetime
        example: 2024-01-15T14:45:00Z

  PriceAggregation:
    description: Aggregated price statistics for a period
    type: object
    properties:
      period_start:
        type: datetime
        example: 2024-01-01T00:00:00Z
      period_end:
        type: datetime
        example: 2024-01-31T23:59:59Z
      min_price:
        type: number | nil
        example: 24.99
      max_price:
        type: number | nil
        example: 34.99
      avg_price:
        type: number | nil
        example: 29.49
      min_rrp:
        type: number | nil
        example: 39.99
      max_rrp:
        type: number | nil
        example: 39.99
      avg_rrp:
        type: number | nil
        example: 39.99
      record_count:
        type: integer
        example: 31

  PriceHistoryResponse:
    description: Price history response with product context
    type: object
    properties:
      product:
        type: object
        properties:
          id:
            type: integer
            example: 123
          asin:
            type: ASIN
            example: B08N5WRWNW
          region:
            type: RegionCode
            example: US
          title:
            type: string
            example: Product Name
      currency:
        type: CurrencyCode
        description: Derived from region
        example: USD
      data:
        type: array
        items: PriceRecord
      aggregations:
        type: array
        items: PriceAggregation
        required: false
        description: Only present if aggregate parameter is specified
      meta:
        type: object
        properties:
          pagination:
            type: Pagination

  #-----------------------------------------------------------------------------
  # User Settings Types
  #-----------------------------------------------------------------------------
  PartnerTags:
    description: Map of region codes to Amazon partner tags
    type: object
    properties:
      US:
        type: string
        required: false
        example: mysite-20
      CA:
        type: string
        required: false
        example: mysite-ca-20
      UK:
        type: string
        required: false
        example: mysite-21
      DE:
        type: string
        required: false
        example: mysite-03
      FR:
        type: string
        required: false
      ES:
        type: string
        required: false
      IT:
        type: string
        required: false
      AU:
        type: string
        required: false
      JP:
        type: string
        required: false
      IN:
        type: string
        required: false
      MX:
        type: string
        required: false
      BR:
        type: string
        required: false

  UserSettings:
    description: User's Amazon PA-API settings
    type: object
    properties:
      id:
        type: integer
        example: 1
      user_id:
        type: integer
        example: 42
      access_key:
        type: string
        description: Amazon PA-API Access Key (secret_key is NEVER returned)
        example: AKIAIOSFODNN7EXAMPLE
      partner_tags:
        type: PartnerTags
      created_at:
        type: datetime
        example: 2024-01-10T08:00:00Z
      updated_at:
        type: datetime
        example: 2024-01-15T12:30:00Z

  UserSettingsUpdateRequest:
    description: Request to create or update user settings
    type: object
    properties:
      access_key:
        type: string
        required: false
        description: Amazon PA-API Access Key
        example: AKIAIOSFODNN7EXAMPLE
      secret_key:
        type: string
        required: false
        description: Amazon PA-API Secret Key (only for updates, never returned)
        example: wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
      partner_tags:
        type: PartnerTags
        required: false
        description: Partner tags are merged with existing; use DELETE to remove

  CredentialsValidationResponse:
    description: Response from credentials validation
    type: object
    properties:
      valid:
        type: boolean
        example: true
      message:
        type: string
        example: Credentials validated successfully

  #-----------------------------------------------------------------------------
  # Blacklist Types
  #-----------------------------------------------------------------------------
  BlacklistEntry:
    description: Blacklisted ASIN/Region combination
    type: object
    properties:
      id:
        type: integer
        example: 1
      asin:
        type: ASIN
        example: B08N5WRWNW
      region:
        type: RegionCode
        example: US
      reason:
        type: string | nil
        description: Optional reason for blacklisting
        example: Prohibited product category
      created_at:
        type: datetime
        example: 2024-01-15T10:30:00Z
      created_by:
        type: integer
        description: Admin user ID who created entry
        example: 1

  BlacklistCreateRequest:
    description: Request to add ASIN/Region to blacklist
    type: object
    properties:
      asin:
        type: ASIN
        example: B08N5WRWNW
      region:
        type: RegionCode
        example: US
      reason:
        type: string
        required: false
        maxLength: 500
        example: Prohibited product category

  BlacklistCheckResponse:
    description: Response from blacklist check
    type: object
    properties:
      blacklisted:
        type: boolean
        example: true
      entry:
        type: BlacklistEntry
        required: false
        description: Present only if blacklisted is true

  #-----------------------------------------------------------------------------
  # Category Types
  #-----------------------------------------------------------------------------
  CategoryListItem:
    description: Category with usage count
    type: object
    properties:
      name:
        type: string
        example: Electronics
      count:
        type: integer
        description: Number of products using this category
        example: 42

  #-----------------------------------------------------------------------------
  # Statistics Types
  #-----------------------------------------------------------------------------
  RegionCount:
    description: Product count for a region
    type: object
    properties:
      region:
        type: RegionCode
        example: US
      count:
        type: integer
        example: 150

  UserDailyStats:
    description: User's daily usage statistics
    type: object
    properties:
      products_created_today:
        type: integer
        example: 12
      daily_limit:
        type: integer | nil
        description: 50 for non-admin, null (unlimited) for admin
        example: 50
      remaining_today:
        type: integer | nil
        description: Remaining creations today (null if unlimited)
        example: 38

  Stats:
    description: Overall API statistics
    type: object
    properties:
      total_products:
        type: integer
        example: 1500
      active_products:
        type: integer
        example: 1450
      total_price_records:
        type: integer
        example: 50000
      products_by_region:
        type: array
        items: RegionCount
      categories_count:
        type: integer
        example: 25
      last_refresh:
        type: datetime
        required: false
        description: Only visible to admins
        example: 2024-01-15T14:00:00Z
      user_stats:
        type: UserDailyStats

  UserStats:
    description: Detailed statistics for current user
    type: object
    properties:
      products_created_today:
        type: integer
        example: 12
      products_created_total:
        type: integer
        example: 245
      daily_limit:
        type: integer | nil
        description: 50 for non-admin, null (unlimited) for admin
        example: 50
      remaining_today:
        type: integer | nil
        example: 38
      is_admin:
        type: boolean
        example: false
      configured_regions:
        type: array
        items: RegionCode
        description: Regions for which user has configured partner tags
        example: [US, UK, DE]

  #-----------------------------------------------------------------------------
  # Health Types
  #-----------------------------------------------------------------------------
  HealthResponse:
    description: API health status
    type: object
    properties:
      status:
        type: string
        example: healthy
      version:
        type: string
        example: "1.0.0"
      wordpress_version:
        type: string
        example: "6.4.2"
      php_version:
        type: string
        example: "8.2.0"
      timestamp:
        type: datetime
        example: 2024-01-15T14:45:00Z

  AmazonHealthResponse:
    description: Amazon PA-API connectivity status
    type: object
    properties:
      status:
        type: HealthStatus
        example: connected
      message:
        type: string
        example: Successfully connected to Amazon PA-API
      response_time_ms:
        type: integer
        required: false
        example: 245

#===============================================================================
# TRAITS
#===============================================================================

traits:
  paginated:
    queryParameters:
      page:
        type: integer
        default: 1
        minimum: 1
        required: false
        description: Page number
        example: 1
      per_page:
        type: integer
        default: 20
        minimum: 1
        maximum: 100
        required: false
        description: Items per page
        example: 20

  sortable:
    queryParameters:
      sort_order:
        type: SortOrder
        default: desc
        required: false
        description: Sort direction

  adminOnly:
    description: Endpoint requires administrator privileges
    responses:
      403:
        description: Forbidden - Admin access required
        body:
          type: Error
          example:
            code: FORBIDDEN
            message: Administrator access required

  publicAccess:
    securedBy: []
    description: Endpoint does not require authentication

#===============================================================================
# RESOURCES
#===============================================================================

/regions:
  displayName: Regions
  description: Amazon marketplace regions
  get:
    displayName: List Regions
    description: Get list of all supported Amazon marketplace regions
    responses:
      200:
        description: List of supported regions
        body:
          type: array
          items: Region
          example:
            - code: US
              name: United States
              marketplace_domain: amazon.com
              currency: USD
            - code: UK
              name: United Kingdom
              marketplace_domain: amazon.co.uk
              currency: GBP

/settings:
  displayName: User Settings
  description: User's Amazon PA-API credentials and partner tags
  
  get:
    displayName: Get Settings
    description: Retrieve current user's settings (secret_key is NEVER returned)
    responses:
      200:
        description: User settings retrieved successfully
        body:
          type: UserSettings
      404:
        description: Settings not configured
        body:
          type: Error
          example:
            code: NOT_FOUND
            message: User settings not configured

  put:
    displayName: Update Settings
    description: |
      Create or update user settings. Partner tags are merged with existing 
      values; use DELETE endpoint to remove specific partner tags.
    body:
      type: UserSettingsUpdateRequest
    responses:
      200:
        description: Settings updated successfully
        body:
          type: UserSettings
      201:
        description: Settings created successfully
        body:
          type: UserSettings
      400:
        description: Validation error
        body:
          type: ValidationError

  /partner-tags/{region}:
    uriParameters:
      region:
        type: RegionCode
        description: Region code to remove partner tag for
        example: US
    delete:
      displayName: Delete Partner Tag
      description: Remove a partner tag for a specific region
      responses:
        204:
          description: Partner tag removed successfully
        404:
          description: Partner tag not found for region
          body:
            type: Error
            example:
              code: NOT_FOUND
              message: No partner tag configured for region US

  /validate:
    post:
      displayName: Validate Credentials
      description: Validate Amazon PA-API credentials by making a test request
      responses:
        200:
          description: Credentials validation result
          body:
            type: CredentialsValidationResponse
        400:
          description: Settings not configured
          body:
            type: Error
            example:
              code: NOT_CONFIGURED
              message: Amazon PA-API credentials not configured

/products:
  displayName: Products
  description: Tracked Amazon products
  
  get:
    displayName: List Products
    description: Retrieve paginated list of all tracked products
    is: [paginated, sortable]
    queryParameters:
      region:
        type: RegionCode
        required: false
        description: Filter by single region
        example: US
      regions:
        type: string
        required: false
        description: Filter by multiple regions (comma-separated)
        example: US,UK,DE
      custom_category:
        type: string
        required: false
        description: Filter by exact category match
        example: Electronics
      search:
        type: string
        minLength: 2
        required: false
        description: Search in title and brand (minimum 2 characters)
        example: wireless
      min_price:
        type: number
        required: false
        description: Minimum current price filter
        example: 10.00
      max_price:
        type: number
        required: false
        description: Maximum current price filter
        example: 100.00
      availability:
        type: string
        enum: [in_stock, out_of_stock, all]
        required: false
        description: Filter by availability status
        example: in_stock
      is_active:
        type: boolean
        default: true
        required: false
        description: Filter by active status
      sort_by:
        type: ProductSortField
        default: created_at
        required: false
        description: Field to sort by
    responses:
      200:
        description: Paginated list of products
        body:
          type: object
          properties:
            data:
              type: array
              items: ProductSummary
            meta:
              type: object
              properties:
                pagination:
                  type: Pagination

  post:
    displayName: Create Product
    description: |
      Create a new tracked product. Process:
      1. Validate ASIN format (10 alphanumeric)
      2. Check blacklist (403 if blacklisted)
      3. Check if already exists (409 if exists)
      4. Validate user has partner tag for region
      5. Fetch from Amazon PA-API
      6. If ASIN not found on Amazon, return 400
      7. Create product with images, facts, initial price record
      
      Rate limit: 50 creations per day for non-admin users (resets midnight UTC)
    body:
      type: ProductCreateRequest
    responses:
      201:
        description: Product created successfully
        body:
          type: Product
      400:
        description: Validation error, ASIN not found, or missing partner tag
        body:
          type: ValidationError | Error
          examples:
            validation:
              code: VALIDATION_ERROR
              message: Request validation failed
              errors:
                - field: asin
                  message: ASIN must be 10 alphanumeric characters
            asin_not_found:
              code: ASIN_NOT_FOUND
              message: Product not found on Amazon
            missing_tag:
              code: MISSING_PARTNER_TAG
              message: No partner tag configured for region US
      403:
        description: ASIN/Region is blacklisted
        body:
          type: BlacklistedError
      409:
        description: Product already exists
        body:
          type: Error
          example:
            code: ALREADY_EXISTS
            message: Product with this ASIN/Region already exists
            details:
              id: 123
      429:
        description: Rate limit exceeded (non-admin users)
        body:
          type: RateLimitError

  /bulk:
    post:
      displayName: Bulk Create Products
      description: |
        Create multiple products in a single request.
        Maximum 100 products per request.
        Counts against daily rate limit for non-admin users.
      body:
        type: ProductBulkCreateRequest
      responses:
        200:
          description: Bulk operation completed (partial success possible)
          body:
            type: ProductBulkResult
        400:
          description: Request validation error
          body:
            type: ValidationError
        429:
          description: Rate limit exceeded
          body:
            type: RateLimitError

  /refresh:
    post:
      displayName: Bulk Refresh Prices
      description: |
        Trigger price refresh for multiple products (Admin only).
        If Amazon PA-API fails for a product, existing price remains unchanged.
      is: [adminOnly]
      body:
        type: ProductRefreshRequest
      responses:
        200:
          description: Refresh completed
          body:
            type: ProductBulkResult
        502:
          description: Amazon PA-API error
          body:
            type: Error
            example:
              code: AMAZON_API_ERROR
              message: Failed to connect to Amazon PA-API

  /{id}:
    uriParameters:
      id:
        type: integer
        description: Unique product ID
        example: 123
    
    get:
      displayName: Get Product
      description: Get full product details by ID
      responses:
        200:
          description: Product details
          body:
            type: Product
        404:
          description: Product not found
          body:
            type: Error
            example:
              code: NOT_FOUND
              message: Product not found

    delete:
      displayName: Delete Product
      description: |
        Delete a product (Admin only).
        - Soft delete (default): Sets is_active=false, preserves price history
        - Hard delete (force=true): Permanently removes product and ALL price history
      is: [adminOnly]
      queryParameters:
        force:
          type: boolean
          default: false
          required: false
          description: If true, permanently delete product and all history
      responses:
        204:
          description: Product deleted successfully
        404:
          description: Product not found
          body:
            type: Error

    /category:
      put:
        displayName: Update Category
        description: Update custom category for a product (Admin only)
        is: [adminOnly]
        body:
          type: CategoryUpdateRequest
        responses:
          200:
            description: Category updated
            body:
              type: Product
          404:
            description: Product not found
            body:
              type: Error

    /prices:
      get:
        displayName: Get Price History
        description: Get price history for a product
        is: [paginated, sortable]
        queryParameters:
          from:
            type: datetime
            required: false
            description: Start of date range
            example: 2024-01-01T00:00:00Z
          to:
            type: datetime
            required: false
            description: End of date range
            example: 2024-01-31T23:59:59Z
          aggregate:
            type: AggregationType
            default: none
            required: false
            description: Aggregation period for price statistics
        responses:
          200:
            description: Price history with optional aggregations
            body:
              type: PriceHistoryResponse
          404:
            description: Product not found
            body:
              type: Error

    /refresh:
      post:
        displayName: Refresh Single Product
        description: |
          Refresh price for a single product (Admin only).
          If Amazon PA-API fails, existing price remains unchanged.
        is: [adminOnly]
        responses:
          200:
            description: Price refreshed successfully
            body:
              type: Product
          404:
            description: Product not found
            body:
              type: Error
          502:
            description: Amazon PA-API error
            body:
              type: Error
              example:
                code: AMAZON_API_ERROR
                message: Failed to fetch price from Amazon

  /by-asin/{asin}:
    uriParameters:
      asin:
        type: ASIN
        description: Amazon Standard Identification Number
        example: B08N5WRWNW
    
    get:
      displayName: Get Products by ASIN
      description: Get all tracked products for an ASIN across all regions
      responses:
        200:
          description: List of products with this ASIN
          body:
            type: array
            items: Product
        404:
          description: No products found for this ASIN
          body:
            type: Error

    /{region}:
      uriParameters:
        region:
          type: RegionCode
          description: Amazon region code
          example: US
      
      get:
        displayName: Get Product by ASIN and Region
        description: Get product by ASIN and region combination
        responses:
          200:
            description: Product details
            body:
              type: Product
          404:
            description: Product not found
            body:
              type: Error

      /prices:
        get:
          displayName: Get Price History by ASIN/Region
          description: Get price history by ASIN/region (same parameters as /products/{id}/prices)
          is: [paginated, sortable]
          queryParameters:
            from:
              type: datetime
              required: false
            to:
              type: datetime
              required: false
            aggregate:
              type: AggregationType
              default: none
              required: false
          responses:
            200:
              description: Price history
              body:
                type: PriceHistoryResponse
            404:
              description: Product not found
              body:
                type: Error

/categories:
  displayName: Categories
  description: Custom product categories
  
  get:
    displayName: List Categories
    description: Get list of all unique custom categories currently in use (Admin only)
    is: [adminOnly]
    responses:
      200:
        description: Alphabetically sorted list of categories with counts
        body:
          type: array
          items: CategoryListItem
          example:
            - name: Electronics
              count: 42
            - name: Home & Garden
              count: 28
            - name: Sports
              count: 15

/blacklist:
  displayName: Blacklist
  description: Blacklisted ASIN/Region combinations
  
  get:
    displayName: List Blacklist
    description: Get paginated list of blacklisted ASIN/Region combinations (Admin only)
    is: [adminOnly, paginated]
    queryParameters:
      region:
        type: RegionCode
        required: false
        description: Filter by region
      search:
        type: string
        required: false
        description: Search by ASIN
    responses:
      200:
        description: Paginated blacklist
        body:
          type: object
          properties:
            data:
              type: array
              items: BlacklistEntry
            meta:
              type: object
              properties:
                pagination:
                  type: Pagination

  post:
    displayName: Add to Blacklist
    description: |
      Add ASIN/Region to blacklist (Admin only).
      If product is currently tracked, it will be soft-deleted.
    is: [adminOnly]
    body:
      type: BlacklistCreateRequest
    responses:
      201:
        description: Added to blacklist
        body:
          type: BlacklistEntry
      400:
        description: Validation error
        body:
          type: ValidationError
      409:
        description: Already blacklisted
        body:
          type: Error
          example:
            code: ALREADY_EXISTS
            message: This ASIN/Region is already blacklisted

  /check:
    get:
      displayName: Check Blacklist
      description: Check if specific ASIN/Region is blacklisted (Admin only)
      is: [adminOnly]
      queryParameters:
        asin:
          type: ASIN
          required: true
          description: ASIN to check
          example: B08N5WRWNW
        region:
          type: RegionCode
          required: true
          description: Region to check
          example: US
      responses:
        200:
          description: Blacklist check result
          body:
            type: BlacklistCheckResponse

  /{id}:
    uriParameters:
      id:
        type: integer
        description: Blacklist entry ID
        example: 1
    
    get:
      displayName: Get Blacklist Entry
      description: Get specific blacklist entry (Admin only)
      is: [adminOnly]
      responses:
        200:
          description: Blacklist entry details
          body:
            type: BlacklistEntry
        404:
          description: Entry not found
          body:
            type: Error

    delete:
      displayName: Remove from Blacklist
      description: Remove ASIN/Region from blacklist (Admin only)
      is: [adminOnly]
      responses:
        204:
          description: Removed from blacklist
        404:
          description: Entry not found
          body:
            type: Error

/stats:
  displayName: Statistics
  description: API usage statistics
  
  get:
    displayName: Get Statistics
    description: |
      Get overall API statistics.
      All authenticated users can access, but admins see additional fields (last_refresh).
    responses:
      200:
        description: API statistics
        body:
          type: Stats

  /user:
    get:
      displayName: Get User Statistics
      description: Get detailed statistics for current user
      responses:
        200:
          description: User statistics
          body:
            type: UserStats

/health:
  displayName: Health
  description: API health checks
  
  get:
    displayName: Health Check
    description: API health status (public endpoint, no authentication required)
    is: [publicAccess]
    responses:
      200:
        description: API health status
        body:
          type: HealthResponse

  /amazon:
    get:
      displayName: Amazon Health Check
      description: Test Amazon PA-API connectivity with user's credentials
      responses:
        200:
          description: Amazon PA-API connectivity status
          body:
            type: AmazonHealthResponse
