<?xml version="1.0"?>
<ruleset name="Amazon Price Tracker Coding Standards">
    <description>PHP CodeSniffer configuration for Amazon Price Tracker WordPress plugin.</description>

    <!-- What to scan -->
    <file>.</file>

    <!-- Exclude paths -->
    <exclude-pattern>/vendor/*</exclude-pattern>
    <exclude-pattern>/node_modules/*</exclude-pattern>
    <exclude-pattern>/tests/*</exclude-pattern>
    <exclude-pattern>/docs/*</exclude-pattern>
    <exclude-pattern>*.min.js</exclude-pattern>
    <exclude-pattern>*.min.css</exclude-pattern>

    <!-- How to scan -->
    <arg value="sp"/> <!-- Show sniff and progress -->
    <arg name="basepath" value="."/>
    <arg name="colors"/>
    <arg name="extensions" value="php"/>
    <arg name="parallel" value="8"/>

    <!-- Rules: WordPress Coding Standards -->
    <rule ref="WordPress">
        <!-- Exclude rules that conflict with PSR-4 autoloading -->
        <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
        <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>

        <!-- Allow short array syntax -->
        <exclude name="Generic.Arrays.DisallowShortArraySyntax"/>

        <!-- Allow modern PHP features -->
        <exclude name="WordPress.PHP.DisallowShortTernary"/>
    </rule>

    <!-- Use WordPress-Extra for additional checks -->
    <rule ref="WordPress-Extra">
        <!-- Same exclusions -->
        <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
        <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
    </rule>

    <!-- WordPress documentation standards -->
    <rule ref="WordPress-Docs">
        <!-- Relax some documentation requirements for internal methods -->
        <exclude name="Squiz.Commenting.FunctionComment.MissingParamTag"/>
    </rule>

    <!-- PHPCompatibility for PHP 7.4+ -->
    <config name="testVersion" value="7.4-"/>

    <!-- WordPress minimum version -->
    <config name="minimum_supported_wp_version" value="5.9"/>

    <!-- Text domain for i18n -->
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="amazon-price-tracker"/>
            </property>
        </properties>
    </rule>

    <!-- Prefixes for functions, classes, etc. -->
    <rule ref="WordPress.NamingConventions.PrefixAllGlobals">
        <properties>
            <property name="prefixes" type="array">
                <element value="apt"/>
                <element value="APT"/>
                <element value="Amazon_Price_Tracker"/>
            </property>
        </properties>
    </rule>

    <!-- Allow specific WordPress globals -->
    <rule ref="WordPress.WP.GlobalVariablesOverride">
        <properties>
            <property name="custom_test_class_whitelist" type="array">
                <element value="APT_Test_Data_Seeder"/>
            </property>
        </properties>
    </rule>

    <!-- Yoda conditions - keep enabled but allow some flexibility -->
    <rule ref="WordPress.PHP.YodaConditions">
        <severity>5</severity>
    </rule>

    <!-- Allow match expressions (PHP 8.0+) when running on PHP 8 -->
    <rule ref="Generic.PHP.Syntax"/>

    <!-- Ensure proper escaping in output -->
    <rule ref="WordPress.Security.EscapeOutput"/>

    <!-- Ensure proper sanitization of input -->
    <rule ref="WordPress.Security.ValidatedSanitizedInput"/>

    <!-- Ensure proper nonce verification -->
    <rule ref="WordPress.Security.NonceVerification"/>

    <!-- Database query security -->
    <rule ref="WordPress.DB.PreparedSQL"/>
    <rule ref="WordPress.DB.PreparedSQLPlaceholders"/>

    <!-- Line length - allow longer lines for SQL queries and URLs -->
    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="120"/>
            <property name="absoluteLineLimit" value="200"/>
        </properties>
    </rule>

    <!-- Cyclomatic complexity warning -->
    <rule ref="Generic.Metrics.CyclomaticComplexity">
        <properties>
            <property name="complexity" value="10"/>
            <property name="absoluteComplexity" value="20"/>
        </properties>
    </rule>

    <!-- Nesting level warning -->
    <rule ref="Generic.Metrics.NestingLevel">
        <properties>
            <property name="nestingLevel" value="4"/>
            <property name="absoluteNestingLevel" value="6"/>
        </properties>
    </rule>
</ruleset>
